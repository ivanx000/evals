{
  "name": "evals",
  "version": "0.1.0",
  "description": "evals — benchmark and compare LLMs",
  "main": "dist/cli.js",
  "bin": {
    "evals": "dist/cli.js",
    "llmeval": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dashboard:dev": "concurrently -n server,ui -c blue,green \"ts-node src/dashboard/start-dev.ts\" \"cd dashboard-ui && npm run dev\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "ajv": "^8.20.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "jsonpath-plus": "^10.4.0",
    "open": "^11.0.0",
    "openai": "^4.85.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
